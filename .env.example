# ─── Database (local Postgres via docker-compose) ───────────────────────────
DATABASE_URL=postgres://kwhab:kwhab@localhost:5433/kwhab

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=4000

# ─── AI mode ────────────────────────────────────────────────────────────────
# mock  = deterministic offline responses, no keys needed (default for dev/demo-safe)
# live  = real OpenRouter + ElevenLabs calls (requires keys below)
AI_MODE=mock

# ─── OpenRouter (LLM: simplification, extraction, NL search) ────────────────
# Single provider, OpenAI-compatible API. Pick a cheap model.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-001
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ─── ElevenLabs (TTS read-aloud + Scribe STT for voice admin) ───────────────
# ONE key, ONE vendor for BOTH directions of voice. If this fails, read-aloud
# AND voice-create both go down — interfaces stay swappable to a browser fallback.
ELEVENLABS_API_KEY=
ELEVENLABS_TTS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_STT_MODEL=scribe_v1

# ─── Web (Vite) ─────────────────────────────────────────────────────────────
# The web dev server proxies /api -> http://localhost:PORT (see web/vite.config.ts)
VITE_API_BASE=/api
